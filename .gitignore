# Visual Studio 2015 user specific files
EctoFarm/.vs/

# Compiled Object files
EctoFarm/*.slo
EctoFarm/*.lo
EctoFarm/*.o
EctoFarm/*.obj

# Precompiled Headers
EctoFarm/*.gch
EctoFarm/*.pch

# Compiled Dynamic libraries
EctoFarm/*.so
EctoFarm/*.dylib
EctoFarm/*.dll

# Fortran module files
EctoFarm/*.mod

# Compiled Static libraries
EctoFarm/*.lai
EctoFarm/*.la
EctoFarm/*.a
EctoFarm/*.lib

# Executables
EctoFarm/*.exe
EctoFarm/*.out
EctoFarm/*.app
EctoFarm/*.ipa

# These project files can be generated by the engine
EctoFarm/*.xcodeproj
EctoFarm/*.xcworkspace
EctoFarm/*.sln
EctoFarm/*.suo
EctoFarm/*.opensdf
EctoFarm/*.sdf
EctoFarm/*.VC.db
EctoFarm/*.VC.opendb
EctoFarm/.vsconfig

# Precompiled Assets
EctoFarm/SourceArt/**/*.png
EctoFarm/SourceArt/**/*.tga

# Binary Files
EctoFarm/Binaries/**
EctoFarm/Plugins/**/Binaries/**

# Builds
EctoFarm/Build/**

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!EctoFarm/Build/*/
EctoFarm/Build/*/**
!EctoFarm/Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!EctoFarm/Build/**/*.ico

# Built data for maps
*EctoFarm/_BuiltData.uasset

# Configuration files generated by the Editor
EctoFarm/Saved/**
EctoFarm/Saved/*

# Compiled source files for the engine to use
EctoFarm/Intermediate/**
Plugins/**/Intermediate/**

# Cache files for the editor to use
DerivedDataCache/**
